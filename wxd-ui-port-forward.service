[Unit]
Description=watsonx.data UI Port Forward (9443→443)
After=network.target

[Service]
Type=simple
User=root
ExecStart=/usr/bin/kubectl port-forward -n wxd svc/lhconsole-ui-svc 9443:443 --address=0.0.0.0
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target