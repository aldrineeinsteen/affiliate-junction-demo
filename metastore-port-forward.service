[Unit]
Description=Hive Metastore Port Forward (9083→8381)
After=network.target

[Service]
Type=simple
User=root
ExecStart=/usr/bin/kubectl port-forward -n wxd svc/ibm-lh-mds-thrift-svc 9083:8381 --address=0.0.0.0
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target